  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Welcome to your new journey, Pilgrim!\n\nTrials are coming around at the
    Royal Palace for those destined to \nbecome the King's Loyal Knights, and you
    desire to prove your \nworth to the king!\n\nHowever, the trials you may face
    may not be as \nconventional as you thought... \nMonsters keep appearing around
    your village, day and night! \nClear them away and uncover where they originate
    to display \nyour strength to your fellow pilgrims and the kingdom as a whole!\n\n\nINSTRUCTIONS:\n\n1.
    Press WASD or the arrow keys to move!\n\n2. Click with your left mouse to attack
    and right mouse to shield!\n\n3. Press SPACEBAR to jump!\n\nHOW TO PLAY\n\nWipe
    out all of the monsters you find in each area. Once you have uncovered enough
    information about where to go next, you'll reach the next stage.\n\n\nGood luck,
    dear pilgrim!\n\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: d363d2c483c6243489ead13bef045e85, type: 2}
